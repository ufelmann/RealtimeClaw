# RealtimeClaw Configuration
# Copy to .env and fill in your values: cp .env.example .env

# === Required ===
XAI_API_KEY=your-api-key-here

# === Provider ===
# REALTIME_PROVIDER=xai               # xai | openai | inworld
# REALTIME_WS_URL=                    # override WebSocket URL (leave blank for provider default)
# REALTIME_VOICE=eve                  # eve | ara | rex | sal | leo  (xAI voices)

# === Wyoming Server ===
# WYOMING_PORT=10300

# === Audio ===
# REALTIME_INPUT_AUDIO_RATE=16000     # 8000 | 16000 | 22050 | 24000 | 32000 | 44100 | 48000
# REALTIME_OUTPUT_AUDIO_RATE=16000

# === VAD (Voice Activity Detection) ===
# REALTIME_VAD_THRESHOLD=0.85         # 0.1–0.9  — higher = louder audio required to trigger
# REALTIME_SILENCE_DURATION_MS=700    # 0–10000  — silence before turn ends; higher = more natural pauses
# REALTIME_PREFIX_PADDING_MS=333      # 0–10000  — audio prepended before speech starts

# === Transcription ===
# REALTIME_TRANSCRIPTION_MODEL=grok-2-audio   # model for user speech transcripts

# === Assistant Identity ===
# ASSISTANT_NAME=Assistant
# ASSISTANT_LANGUAGES=de,en
# REALTIME_INSTRUCTIONS=              # system prompt / personality

# === Home Assistant Direct Integration ===
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=your-long-lived-access-token

# === OpenClaw Integration (optional, but required for soul/memory/tools) ===
# OPENCLAW_URL=http://openclaw:18789        # required if using OpenClaw
# OPENCLAW_TOKEN=your-openclaw-gateway-token  # required if OPENCLAW_URL is set
# OPENCLAW_TIMEOUT_MS=10000
# OPENCLAW_DEVICE_STORE=./openclaw-device.json   # persists Ed25519 device credentials for pairing

# === Speaker Identification (Picovoice Eagle — optional) ===
# EAGLE_ENABLED=false
# EAGLE_ACCESS_KEY=your-picovoice-access-key
# EAGLE_MODEL_PATH=/data/eagle-model.pv
# EAGLE_VOICEPRINTS_DIR=/data/voiceprints
# EAGLE_CONFIDENCE_THRESHOLD=0.7
# EAGLE_IDENTIFY_FRAMES=10

# === Speaker / Security Mapping (JSON) ===
# SPEAKER_DEVICE_MAP={"kitchen":"alice","living_room":"family"}
# SPEAKER_CONFIG={"alice":{"displayName":"Alice","contextKey":"alice"}}
# SPEAKER_MAX_LEVELS={"alice":"owner","bob":"owner","charlie":"family"}

# === Security Thresholds ===
# SECURITY_THRESHOLD_FAMILY=0.50
# SECURITY_THRESHOLD_TRUSTED=0.70
# SECURITY_THRESHOLD_OWNER=0.90

# === Tool Routing ===
# TOOL_ROUTE_DIRECT=ha_*,sonos_*,spotify_*,paperless_*,calendar_*
# TOOL_ROUTE_REASONING=request_reasoning
# TOOL_ROUTE_DANGEROUS=exec_*,file_delete_*

# === JSON Config File (overrides all env vars) ===
# CONFIG_FILE=/data/config.json

# === Debug ===
# DEBUG_REALTIME_CLAW=false
